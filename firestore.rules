rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { 
      return isSignedIn() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        request.auth.token.email in ['idin@agape.nyc', 'agape@sovereign.nyc']
      ); 
    }
    
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- Entity Validations ---

    function isValidUser(data) {
      return data.uid == request.auth.uid 
        && data.email is string && data.email.size() <= 128
        && data.role in ['user', 'admin']
        && data.sovereignScore is number && data.sovereignScore >= 0 && data.sovereignScore <= 100
        && (data.displayName == null || (data.displayName is string && data.displayName.size() <= 64));
    }

    function isValidScanFinding(data) {
      return data.userId == request.auth.uid
        && data.module is string && data.module.size() <= 32
        && data.finding is string && data.finding.size() <= 256
        && data.status in ['NUKED', 'KNOXED', 'MONITORED']
        && data.details is string && data.details.size() <= 5000;
    }

    function isValidScoreHistory(data) {
      return data.userId == request.auth.uid
        && data.score is number && data.score >= 0 && data.score <= 100
        && data.nukedCount is number && data.knoxedCount is number && data.monitoredCount is number
        && data.findings is list && data.findings.size() <= 50;
    }

    function isValidAuditLog(data) {
      return data.type is string && data.type.size() <= 64
        && data.action is string && data.action.size() <= 512
        && (data.userId == null || (data.userId is string && data.userId.size() <= 128))
        && (data.userEmail == null || (data.userEmail is string && data.userEmail.size() <= 128));
    }

    // --- Collection Routes ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow create: if isSignedIn() 
        && isValidUser(incoming()) 
        && incoming().createdAt == request.time
        && (incoming().role == 'user' || isAdmin()); 
      
      allow update: if isOwner(userId) 
        && isValidUser(incoming())
        && incoming().uid == existing().uid
        && incoming().createdAt == existing().createdAt
        && (
          (incoming().diff(existing()).affectedKeys().hasOnly(['sovereignScore'])) ||
          (incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'email'])) ||
          (isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['role']))
        );
    }

    match /diff_scans/{scanId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() 
        && isValidScanFinding(incoming())
        && incoming().timestamp == request.time;
      
      allow update: if isSignedIn() 
        && resource.data.userId == request.auth.uid
        && isValidScanFinding(incoming())
        && incoming().userId == existing().userId
        && incoming().module == existing().module
        && (
          incoming().diff(existing()).affectedKeys().hasOnly(['status'])
        );
      
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /score_history/{historyId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() 
        && isValidScoreHistory(incoming())
        && incoming().timestamp == request.time;
      
      allow update, delete: if false;
    }

    match /audit_logs/{logId} {
      allow list: if isAdmin();
      allow get: if isAdmin();
      allow create: if isSignedIn() 
        && isValidAuditLog(incoming())
        && incoming().timestamp == request.time;
      
      allow update, delete: if false;
    }
